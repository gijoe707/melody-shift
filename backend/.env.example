SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:5173/auth/callback
FRONTEND_URL=http://localhost:5173

# YouTube Music Authentication (For Public Playlists - Server Side)
# Get these 3 values from YouTube Music Network tab (F12 → Network → browse request → Request Headers)
# REQUIRED - These 3 are unique to your account:
OAUTH_COOKIE="your_cookie_from_network_tab"
OAUTH_AUTHORIZATION="your_authorization_from_network_tab"
OAUTH_X_GOOG_VISITOR_ID="your_x_goog_visitor_id_from_network_tab"

# OPTIONAL - These are defaults that should work for most users:
# OAUTH_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:145.0) Gecko/20100101 Firefox/145.0"
# OAUTH_ACCEPT="*/*"
# OAUTH_ACCEPT_LANGUAGE="en-US,en;q=0.5"
# OAUTH_CONTENT_TYPE="application/json"
# OAUTH_REFERER="https://music.youtube.com/"
# OAUTH_X_YOUTUBE_BOOTSTRAP_LOGGED_IN="true"
# OAUTH_X_YOUTUBE_CLIENT_NAME="67"
# OAUTH_X_YOUTUBE_CLIENT_VERSION="1.20251117.03.00"
# OAUTH_X_GOOG_AUTHUSER="0"
# OAUTH_X_ORIGIN="https://music.youtube.com"
# OAUTH_ORIGIN="https://music.youtube.com"
# OAUTH_SEC_FETCH_DEST="empty"
# OAUTH_SEC_FETCH_MODE="same-origin"
# OAUTH_SEC_FETCH_SITE="same-origin"